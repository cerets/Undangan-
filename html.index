    <script>
    // =======================
// 🔧 CONFIG
// =======================
const nomorWA = "6282118366357";

// =======================
// 🔐 ADMIN MODE
// =======================
function isAdmin() {
  const params = new URLSearchParams(window.location.search);
  return params.get("admin") === "true";
}

// =======================
// 💬 POPUP
// =======================
function showPopup(message) {
  alert(message); // sementara pakai alert dulu biar aman
}

// =======================
// 📝 KIRIM RSVP
// =======================
function kirimWA() {
  const nama = document.getElementById("nama").value.trim();
  const status = document.getElementById("status").value;
  const pesan = document.getElementById("pesan").value.trim();
  const jumlah = document.getElementById("jumlah")?.value || 1;

  if (!nama || !status) {
    showPopup("Isi nama dan kehadiran dulu ya 🙏");
    return;
  }

  simpanRSVP(nama, status, jumlah, pesan);

  const text = encodeURIComponent(
    `Halo, saya ${nama}\nKonfirmasi: ${status}\nJumlah: ${jumlah}\nPesan: ${pesan}`
  );

  const url = `https://wa.me/${nomorWA}?text=${text}`;
  window.open(url, "_blank");
}

// =======================
// ☁️ FIREBASE
// =======================
function simpanRSVP(nama, status, jumlah, pesan) {
  db.ref("rsvp").push({
    nama,
    status,
    jumlah,
    pesan,
    waktu: Date.now()
  });
}

// =======================
// 📋 LOAD DATA
// =======================
function loadRSVP() {
  const list = document.getElementById("guest-list");
  const hadirEl = document.getElementById("hadir-count");
  const tidakEl = document.getElementById("tidak-count");

  if (!list) return;

  let hadir = 0;
  let tidak = 0;

  db.ref("rsvp").on("child_added", (snapshot) => {
    const data = snapshot.val();

    const item = document.createElement("div");

    const statusClass =
      data.status === "Hadir" ? "color:green" : "color:red";

    if (data.status === "Hadir") hadir++;
    else tidak++;

    hadirEl.innerText = hadir + " Hadir";
    tidakEl.innerText = tidak + " Tidak Hadir";

    item.innerHTML = `
      <b>${data.nama}</b><br>
      <span style="${statusClass}">${data.status}</span><br>
      ${data.jumlah} orang
      <p>${data.pesan || ""}</p>
    `;

    list.prepend(item);
  });
}

// =======================
// INIT
// =======================
document.addEventListener("DOMContentLoaded", () => {
  loadRSVP();

  if (!isAdmin()) {
    const panel = document.getElementById("admin-panel");
    if (panel) panel.style.display = "none";
  }
});
    
    </script>
    <script>
    
    const btn = document.querySelector(".hero a");

btn.addEventListener("click", function(e) {
  e.preventDefault();

  const rect = btn.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;

  /* 🌊 RIPPLE */
  const ripple = document.createElement("span");
  ripple.className = "ripple";

  const size = Math.max(rect.width, rect.height);
  ripple.style.width = ripple.style.height = size + "px";
  ripple.style.left = (x - size/2) + "px";
  ripple.style.top = (y - size/2) + "px";

  btn.appendChild(ripple);

  /* ✨ SPARKLE BURST */
  for (let i = 0; i < 8; i++) {
    const spark = document.createElement("span");
    spark.className = "spark-click";

    const angle = Math.random() * 2 * Math.PI;
    const distance = 40 + Math.random() * 40;

    spark.style.left = x + "px";
    spark.style.top = y + "px";
    spark.style.setProperty("--x", Math.cos(angle) * distance + "px");
    spark.style.setProperty("--y", Math.sin(angle) * distance + "px");

    btn.appendChild(spark);

    setTimeout(() => spark.remove(), 800);
  }

  /* ⚡ FLASH */
  const flash = document.createElement("span");
  flash.className = "flash";
  btn.appendChild(flash);

  setTimeout(() => {
    ripple.remove();
    flash.remove();
  }, 700);

  /* 📳 VIBRATION (HP) */
  if (navigator.vibrate) {
    navigator.vibrate(20);
  }

  /* ⏳ DELAY TRANSISI */
  setTimeout(() => {
    window.location.href = btn.getAttribute("href");
  }, 500);
});
    
    </script>
    
    <script>
const track = document.querySelector(".slider-track");
const images = document.querySelectorAll(".slider-track img");
const bg = document.querySelector(".galeri-bg");

let index = 0;

/* 🔥 UPDATE BACKGROUND */
function updateBackground() {
  const activeImg = images[index];
  if (activeImg) {
    bg.style.backgroundImage = `url(${activeImg.src})`;
  }
}

/* 🔥 UPDATE SLIDER + CENTER + ACTIVE */
function updateSlider() {
  const container = document.querySelector(".gallery-slider");

  const containerWidth = container.offsetWidth;
  const imgWidth = images[0].offsetWidth + 12;

  const offset = (containerWidth / 2) - (imgWidth / 2);

  track.style.transform = `translateX(${offset - index * imgWidth}px)`;

  images.forEach(img => img.classList.remove("active"));
  images[index].classList.add("active");

  updateBackground();
}

/* AUTO SLIDE */
setInterval(() => {
  index++;
  if (index >= images.length) index = 0;
  updateSlider();
}, 3000);

/* SWIPE */
let startX = 0;

track.addEventListener("touchstart", e => {
  startX = e.touches[0].clientX;
});

track.addEventListener("touchend", e => {
  let endX = e.changedTouches[0].clientX;

  if (startX > endX + 50) index++;
  else if (startX < endX - 50) index--;

  if (index < 0) index = 0;
  if (index >= images.length) index = images.length - 1;

  updateSlider();
});

/* LIGHTBOX */
const lightbox = document.getElementById("lightbox");
const lightboxImg = document.getElementById("lightbox-img");

images.forEach((img, i) => {
  img.addEventListener("click", () => {
    index = i; // 🔥 klik jadi active + center
    updateSlider();

    lightbox.classList.add("active");
    lightboxImg.src = img.src;
  });
});

lightbox.addEventListener("click", () => {
  lightbox.classList.remove("active");
});

/* INIT */
updateSlider();
    images.forEach((img, i) => {
  img.addEventListener("click", () => {
    console.log("klik jalan", i);
  });
});
    
    </script>
    
    
  </body>
