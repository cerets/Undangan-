  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
  // ===== HERO CINEMATIC LOAD =====
window.addEventListener("load", () => {
  const items = document.querySelectorAll(".cinematic");

  items.forEach((el, i) => {
    setTimeout(() => {
      el.classList.add("show");
    }, i * 300);
  });

  // tombol terakhir
  const btn = document.getElementById("open-btn");
  setTimeout(() => {
    btn.classList.add("show");
  }, 1500);document.body.classList.add("loaded");
});
   
      
const targetDate = new Date("2026-06-13 08:00:00").getTime();

let lastSecond = null;

const countdown = setInterval(() => {
  const now = new Date().getTime();
  const selisih = targetDate - now;

  if (selisih <= 0) {
    clearInterval(countdown);
    document.getElementById("countdown").innerHTML = "<h3>Acara telah dimulai 🎉</h3>";
    return;
  }

  const hari = Math.floor(selisih / (1000 * 60 * 60 * 24));
  const jam = Math.floor((selisih % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  const menit = Math.floor((selisih % (1000 * 60 * 60)) / (1000 * 60));
  const detik = Math.floor((selisih % (1000 * 60)) / 1000);

  document.getElementById("days").innerText = hari;
  document.getElementById("hours").innerText = jam;
  document.getElementById("minutes").innerText = menit;

  // 🔥 animasi cuma saat detik berubah
  if (detik !== lastSecond) {
    const el = document.getElementById("seconds");
    el.classList.add("pop");
    setTimeout(() => el.classList.remove("pop"), 300);
    lastSecond = detik;
  }

  document.getElementById("seconds").innerText = detik;

}, 1000);
     
     
     
    
    
    <!-- buka undangan -->
document.addEventListener("DOMContentLoaded", () => {

  // ==============================
  // 🔐 FINGERPRINT (OPEN COVER)
  // ==============================
  document.body.classList.add("locked");

  const fp = document.getElementById("fingerprint");
  const cover = document.getElementById("cover");
  const music = document.getElementById("bg-music");
  const musicBtn = document.getElementById("music-toggle");
  
  // AUDIO ANALYSER
  let audioCtx, analyser, dataArray;

  function initAudio() {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const source = audioCtx.createMediaElementSource(music);
    analyser = audioCtx.createAnalyser();

    source.connect(analyser);
    analyser.connect(audioCtx.destination);

    analyser.fftSize = 64;
    dataArray = new Uint8Array(analyser.frequencyBinCount);
  }

  function getBeat() {
    if (!analyser) return 0;
    analyser.getByteFrequencyData(dataArray);

    let sum = 0;
    for (let i = 0; i < 10; i++) sum += dataArray[i];
    return sum / 10;
  }
  
  
  if (fp) {
    fp.addEventListener("click", () => {
      if (fp.classList.contains("active")) return;

      fp.classList.add("active");

      if (navigator.vibrate) navigator.vibrate([30, 50, 30]);

      setTimeout(() => {
        fp.classList.add("success");
      }, 900);

      setTimeout(() => {
        cover.classList.add("hide");
        document.body.classList.remove("locked");

        window.scrollTo({
          top: 0,
          behavior: "smooth"
        });

        // 🎵 PLAY MUSIK
if (music) {
          if (!audioCtx) initAudio();
          if (audioCtx.state === "suspended") audioCtx.resume();

          music.volume = 0;
          music.play();

          let vol = 0;
          const fade = setInterval(() => {
            if (vol < 0.5) {
              vol += 0.05;
              music.volume = vol;
            } else clearInterval(fade);
          }, 100);

          if (musicBtn) musicBtn.classList.add("active");
        }

      }, 1400);
    });
  }

  // ==============================
  // 🎵 MUSIC TOGGLE BUTTON
  // ==============================
  // TOGGLE MUSIC
  if (music && musicBtn) {
    musicBtn.addEventListener("click", () => {

      if (!audioCtx) initAudio();
      if (audioCtx.state === "suspended") audioCtx.resume();

      if (music.paused) {
        music.play();
        musicBtn.classList.add("active");
      } else {
        music.pause();
        musicBtn.classList.remove("active");
      }

    });
  }
/* ===============================
     ✨ SPARKLE BEAT SYNC
  =============================== */
  let lastSpawn = 0;

  document.addEventListener("touchmove", (e) => {

    const now = Date.now();
    if (now - lastSpawn < 60) return;
    lastSpawn = now;

    const touch = e.touches[0];
    const beat = getBeat();
    const intensity = beat / 255;

    const count = 1 + Math.floor(intensity * 3);

    for (let i = 0; i < count; i++) {

      const s = document.createElement("div");
      s.className = "sparkle";

      const x = touch.clientX + (Math.random() - 0.5) * 20;
      const y = touch.clientY + (Math.random() - 0.5) * 20;

      const size = 6 + intensity * 12;

      s.style.left = x + "px";
      s.style.top = y + "px";
      s.style.width = size + "px";
      s.style.height = size + "px";

      s.style.boxShadow = `
        0 0 ${10 + intensity * 20}px #fff,
        0 0 ${20 + intensity * 40}px #f14e95
      `;

      document.body.appendChild(s);
      setTimeout(() => s.remove(), 700);
    }

  });
  
  /* ===============================
     🍔 ASSISTIVE MENU
  =============================== */
  const atBtn = document.getElementById("at-btn");
  const assistive = document.getElementById("assistive");

  if (atBtn && assistive) {
    atBtn.addEventListener("click", () => {
      assistive.classList.toggle("active");
    });
  }

 /* ===============================
     🧲 DRAG ASSISTIVE
  =============================== */
  if (assistive) {
    let dragging = false, offsetX, offsetY;

    assistive.addEventListener("touchstart", (e) => {
      dragging = true;
      const rect = assistive.getBoundingClientRect();
      offsetX = e.touches[0].clientX - rect.left;
      offsetY = e.touches[0].clientY - rect.top;
    });

    document.addEventListener("touchmove", (e) => {
      if (!dragging) return;

      assistive.style.left = (e.touches[0].clientX - offsetX) + "px";
      assistive.style.top = (e.touches[0].clientY - offsetY) + "px";
      assistive.style.right = "auto";
      assistive.style.bottom = "auto";
    });

    document.addEventListener("touchend", () => dragging = false);
  }
  
  

  // ==============================
  // 🌊 PARALLAX SCROLL (HALUS)
  // ==============================
  const elements = document.querySelectorAll(".parallax");

  let ticking = false;

  function updateParallax() {
    const scrollY = window.scrollY;

    elements.forEach(el => {
      const speed = parseFloat(el.dataset.speed) || 0.3;
      el.style.transform = `translateY(${scrollY * speed}px)`;
    });

    ticking = false;
  }

  window.addEventListener("scroll", () => {
    if (!ticking) {
      window.requestAnimationFrame(updateParallax);
      ticking = true;
    }
  });

});
     /* ===============================
     👤 GUEST NAME (PERSONAL LINK)
  =============================== */
  function getGuestName() {
    const params = new URLSearchParams(window.location.search);
    let name = params.get("to");

    if (!name) return "Tamu Undangan";

    name = decodeURIComponent(name)
      .replace(/\+/g, " ")
      .replace(/%20/g, " ");

    return name;
  }

  function setGuestName() {
    const el = document.getElementById("guest-name");
    if (!el) return;

    const name = getGuestName();
    el.innerText = "Kepada Yth. " + name;
  }

  setGuestName();
     const inputNama = document.getElementById("nama");
if (inputNama) {
  inputNama.value = getGuestName();
}


</script>
 
  
<script>
function copyRek(id) {
  const text = document.getElementById(id).innerText;
  navigator.clipboard.writeText(text);

  alert("Nomor rekening berhasil disalin");
}
</script>

<script>
