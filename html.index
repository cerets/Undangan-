     // ================= IDLE =================
let idleTimer;

function setIdle() {
  assistiveTouch.classList.add("idle");
}

function resetIdle() {
  assistiveTouch.classList.remove("idle");

  clearTimeout(idleTimer);
  idleTimer = setTimeout(setIdle, 3000);
}

// event interaksi
["touchstart", "touchmove", "click"].forEach(evt => {
  assistiveTouch.addEventListener(evt, resetIdle);
});


